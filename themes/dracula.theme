# cmonkey theme — dracula
# empty value = use terminal default (transparent)

# base
theme[bg]="#282a36"
theme[fg]="#f8f8f2"

# typing
theme[correct]="#50fa7b"
theme[wrong]="#ff5555"
theme[dim]="#44475a"

# ui
theme[accent]="#bd93f9"
theme[cursor]="#f8f8f2"
theme[warning]="#ffb86c"

# border + cursor appearance live in the theme file
theme[border_style]="rounded"
theme[cursor_style]="bar"
